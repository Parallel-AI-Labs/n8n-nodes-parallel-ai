{
  "name": "@parallel-ai/n8n-nodes-parallel-ai",
  "version": "0.4.2",
  "description": "n8n nodes for Parallel AI",
  "author": {
    "name": "Parallel AI",
    "email": "support@parallellabs.app",
    "url": "https://parallellabs.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Parallel-AI-Labs/n8n-nodes-parallel-ai.git"
  },
  "homepage": "https://github.com/Parallel-AI-Labs/n8n-nodes-parallel-ai#readme",
  "bugs": {
    "url": "https://github.com/Parallel-AI-Labs/n8n-nodes-parallel-ai/issues"
  },
  "keywords": [
    "n8n-nodes",
    "n8n-custom-nodes",
    "parallel-ai",
    "n8n-community-node-package"
  ],
  "files": [
    "dist",
    "logo.png"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ParallelAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ParallelAi/ParallelAi.node.js",
      "dist/nodes/KnowledgeBaseRetriever/ParallelAiKnowledgeBaseRetriever.node.js",
      "dist/nodes/BrowserTask/ParallelAiBrowserTask.node.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist .tsbuildinfo",
    "build": "npm run clean && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/express": "^4.17.6",
    "@types/request-promise-native": "~1.0.15",
    "@typescript-eslint/parser": "~5.45",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-core": "*",
    "n8n-workflow": "*",
    "prettier": "^2.7.1",
    "typescript": "~4.8.4"
  },
  "license": "MIT"
}
